<div class="row">
  <div class="col-md-6">
    <%= image_tag(listing.photo, class: "img-fluid mb-3") %>
  </div>
  <div class="col-md-6">
    <h2><%= listing.title %></h2>
    <p><%= listing.address %></p>
    <p><%= listing.description %></p>
    <%= link_to "Book a Viewing", new_listing_bookings_path(listing), class: "btn btn-primary" %>
  </div>
</div>