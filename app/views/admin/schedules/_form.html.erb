<%= form_with model: @schedule, scope: :schedule, url: admin_listing_schedules_path do |form| %>
  <% if @schedule.errors.any? %>
    <p class="text-danger">
      <%= @schedule.errors.full_messages.to_sentence.capitalize %>
    </p>
  <% end %>
  <div class="d-flex mb-3">
    <%= form.time_select :start_time, combined: true, minute_interval: 15, time_separator: "", class: "form-control-sm" %> &nbsp;
    <%= form.number_field :duration, step: 10,class: "form-control-sm", placeholder: "Duration in minutes" %>
    <div class="d-none">
      <%= form.date_select :start_time, selected: date.to_date %>
    </div>
    <%= form.hidden_field :listing_id, value: params[:listing_id] %>
  </div>
  <%= form.submit "Save", class: "btn btn-sm btn-primary" %>
  <%= link_to "Cancel", admin_listing_availabilities_path(@schedule.listing_id, date: @schedule.start_time.to_date), class: "btn btn-sm btn-secondary", data: { turbo_frame: "new_availability" } %>
<% end %>