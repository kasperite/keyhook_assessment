<%= turbo_stream.update 'new_availability' do %>
  <%= link_to "Add", new_admin_listing_schedule_path(@schedule.listing_id, date: @schedule.start_time.to_date), class: "btn btn-sm btn-primary", data: { turbo_stream: true } %>
<% end %>

<%= turbo_stream.append dom_id(@availability.listing) do %>
  <%= render @availability %>
<% end %>

<%= turbo_stream.replace "date_#{@schedule.start_time.to_date.to_time.to_i}" do %>
  <%= link_to @schedule.start_time.to_date.day, admin_listing_availabilities_path(@schedule.listing_id, date: @schedule.start_time.to_date), data: { turbo_frame: "modal" }, class: "btn btn-sm btn-primary position-relative" %>
<% end %>