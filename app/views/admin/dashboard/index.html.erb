<div class="p-4 border bg-light w-50 mx-auto">
  <h1>Admin Dashboard</h1>
  <p><%= button_to "Sign Out", session_path, method: :delete, class: "btn btn-danger" %></p>
  <%= month_calendar(events: @availabilities) do |date, availabilities| %>
    <%= turbo_frame_tag "date_#{date.to_time.to_i}" do %>
      <%= link_to admin_user_availabilities_path(Current.user, date: date), data: { turbo_frame: "modal" }, class: "btn btn-sm #{availabilities.any? ? 'btn-primary' : 'btn-outline-secondary'} position-relative" do %>
        <%= date.day %>

        <% count = availabilities.select { |a| a.status == "booked" }.count %>
        <% if count > 0 %>
          <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
            <%= count %>
          </span>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
</div>